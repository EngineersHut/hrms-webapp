{
  "name": "hrms-desktop",
  "productName": "HRMS",
  "version": "1.0.0",
  "description": "Enterprise HRMS Desktop Application",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder -wlm"
  },
  "keywords": [
    "HRMS",
    "Desktop",
    "Electron",
    "Enterprise"
  ],
  "author": {
    "name": "HRMS Team",
    "email": "support@hrms.com"
  },
  "homepage": "https://hrms.ehworkspace.com",
  "license": "UNLICENSED",
  "dependencies": {
    "electron-log": "^5.1.5",
    "electron-updater": "^6.1.8"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.ehworkspace.hrms",
    "productName": "HRMS",
    "directories": {
      "output": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HRMS",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.business"
    },
    "dmg": {
      "background": null,
      "backgroundColor": "#ffffff",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "title": "${productName} Installer"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "icon": "assets/icon.png",
      "synopsis": "HRMS Desktop Application",
      "description": "Enterprise HRMS Desktop Application with Auto-Updates and Tray integration.",
      "maintainer": "HRMS Team <support@hrms.com>",
      "desktop": {
        "Name": "HRMS",
        "Type": "Application",
        "Categories": "Office;"
      }
    },
    "publish": {
      "provider": "generic",
      "url": "https://hrms.ehworkspace.com/downloads/updates"
    }
  }
}
